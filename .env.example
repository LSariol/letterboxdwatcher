# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost/botsuite_db?sslmode=disable

# URL of the downstream notification service (e.g. Twitch bot)
NOTIFICATION_ENDPOINT=http://localhost:8080/notify

# How often the full subscription list is cycled through (minutes)
POLL_INTERVAL_MINUTES=25

# Delay between sending each notification (seconds)
NOTIFICATION_DELAY_SECONDS=3

# Minimum delay between individual RSS feed fetches (seconds)
MIN_FEED_DELAY_SECONDS=5
